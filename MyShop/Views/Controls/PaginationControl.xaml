<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="MyShop.Views.Controls.PaginationControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MyShop.Views.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Orientation="Vertical" Spacing="6">
        <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Center"
                Spacing="4">

            <Button Click="FirstPage_Click" Background="Transparent" BorderBrush="Transparent" 
                BorderThickness="0"
                Padding="0" IsEnabled="{x:Bind Pagination.HasPreviousPage, Mode=OneWay}">
                <Image Source="/Assets/Pagination/first.png" Width="30" Height="30"/>
            </Button>

            <Button Click="PrevPage_Click" Background="Transparent" BorderBrush="Transparent" 
                BorderThickness="0"
                Padding="0" IsEnabled="{x:Bind Pagination.HasPreviousPage, Mode=OneWay}">
                <Image Source="/Assets/Pagination/previous.png" Width="30" Height="30"/>
            </Button>

            <!--<TextBlock Text="{x:Bind PageInfo, Mode=OneWay}"
                   VerticalAlignment="Center"
                   FontWeight="SemiBold"
                   Margin="10,0"/>-->
            <ComboBox Name="PageSizeComboBox"
        Width="120" Height="35"
        ItemsSource="{x:Bind PageOptions, Mode=OneWay}" SelectedItem="{x:Bind SelectedPage, Mode=OneWay}" DisplayMemberPath="Display"  SelectedValuePath="Page" SelectionChanged="PageSizeComboBox_SelectionChanged">
            </ComboBox>

            <Button Click="NextPage_Click" Background="Transparent" BorderBrush="Transparent" 
                BorderThickness="0"
                Padding="0" IsEnabled="{x:Bind Pagination.HasNextPage, Mode=OneWay}">
                <Image Source="/Assets/Pagination/next.png" Width="30" Height="30"/>
            </Button>

            <Button Click="LastPage_Click" Background="Transparent" BorderBrush="Transparent" 
                BorderThickness="0"
                Padding="0" IsEnabled="{x:Bind Pagination.HasNextPage, Mode=OneWay}">
                <Image Source="/Assets/Pagination/last.png" Width="30" Height="30"/>
            </Button>
        </StackPanel>

        <TextBlock Text="{x:Bind ItemsInfo, Mode=OneWay}"
               HorizontalAlignment="Center"
               FontSize="12"
               Opacity="0.7"/>
    </StackPanel>
</UserControl>
